# hosystem — deployment credentials
# Copy to .env (gitignored) and fill in. Never commit .env.

# ── Cloudflare ────────────────────────────────────────────────────────────
# API token for deploying to Cloudflare Pages (project: hosystem).
# Scope needed: Account · Cloudflare Pages · Edit, on the Sageframe account.
# Get/roll it: dashboard → My Profile → API Tokens.
# Used two ways:
#   1. Local deploys without OAuth:  npx wrangler pages deploy _site --project-name hosystem
#   2. Copied into the GitHub Actions secret of the same name (gh secret set
#      CLOUDFLARE_API_TOKEN --repo sageframe-dharma/hosystem), which powers
#      the automated deploys (.github/workflows/deploy.yml).
CLOUDFLARE_API_TOKEN=

# The Sageframe account id (not a secret; here so wrangler and CI agree).
CLOUDFLARE_ACCOUNT_ID=
