<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {% endif %}hosystem</title>
  <meta name="description" content="{{ description or site.tagline }}">
  <link rel="icon" href="/favicon.svg">
  {# §8: body fonts are self-hosted — no third-party requests. Preload the two most-used. #}
  <link rel="preload" href="/fonts/source-serif-4-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/source-code-pro-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/site.css">
</head>
<body>
  {# ── §14 the header (variant D′, single-element — 2026-07-07 amendment: ONE header, not two).
       It rests in its natural slot at the top of the page (sticky, in flow — the slot is
       reserved so nothing reflows); scrolling down it departs as one §4 step; committed upward
       scroll brings the SAME element back, docked at top. header.js drives it. There is only
       ever one rendering of the nav. z-index 5 (the §7 card stays 10). ── #}
  <header class="revealed-header" aria-label="site" data-door="{{ door or '' }}">
    <div class="rh-inner">
      <a class="rh-brand" href="/" aria-label="hosystem—home">{% koma 20, {"mode":"solid","face":"front"} %}</a>
      <nav class="rh-doors" aria-label="primary">
        {%- for d in site.doors %}
        <a href="{{ d.url }}"{% if page.url == d.url or (d.url != "/" and page.url.startsWith(d.url)) %} aria-current="page"{% endif %}>{{ d.name }}</a>
        {%- endfor %}
      </nav>
      <div class="rh-mini" aria-hidden="true"></div>
      {# the client path — right-aligned, set apart from the six doors, never a door ink state #}
      <a class="rh-engage" href="/engagements/"{% if page.url == "/engagements/" %} aria-current="page"{% endif %}>Engagements</a>
    </div>
    <div class="rh-crumb" hidden></div>
    <div class="rh-rule"></div>
  </header>

  <main class="wrap{% if not page.reduced %} step{% endif %}">
    {{ content | safe }}

    {# ── §8 the trail: real localStorage / sessionStorage; recorded on every page ── #}
    {%- if door %}
    <div id="trail" class="trail" data-door="{{ door }}" aria-label="your walk"></div>
    {%- endif %}

    <div class="colophon-rule caption">
      ingested: sharibako @ <code>{{ site.manifest.sources.sharibako.sha | default('—') | truncate(12, true, '') }}</code> ·
      ho-system @ <code>{{ site.manifest.sources["ho-system"].sha | default('—') | truncate(12, true, '') }}</code> ·
      <a class="chain-link" href="/glossary/">the glossary</a> ·
      <a class="chain-link" href="/colophon/">the colophon</a>
    </div>
  </main>

  {# single sources read by the vanilla JS #}
  <script type="application/json" id="plain-cuts">{{ meta.plainCuts | dump | safe }}</script>
  <script type="application/json" id="doors">{{ meta.doors | dump | safe }}</script>

  <script src="/js/defotouch.js" defer></script>
  <script src="/js/reveal.js" defer></script>
  {# flip.js also honors ?flip — a dev-only demo pass of the §9 flip, no witness-log writes #}
  <script src="/js/flip.js" defer></script>
  <script src="/js/trail.js" defer></script>
  <script src="/js/crumb.js" defer></script>
  {# §14 the revealed header; §13 the depth dial + branch-return (after trail.js so ho:met lands) #}
  <script src="/js/header.js" defer></script>
  <script src="/js/dial.js" defer></script>
  <script src="/js/branch.js" defer></script>
  {# dev-only by-feel tuners (spec §7); renders only with ?tuners — inert for visitors #}
  <script src="/js/tuners.js" defer></script>
</body>
</html>
